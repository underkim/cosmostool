{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "displayName": "Windows MSVC · Debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Windows MSVC · RelWithDebInfo",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "debug-analysis",
      "displayName": "Windows MSVC · Debug + Static Analysis",
      "inherits": "debug",
      "cacheVariables": {
        "ENABLE_CLANG_TIDY": "ON"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux/Unix · Debug (system compiler + packages)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTING": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Build Debug",
      "configurePreset": "debug",
      "jobs": 0
    },
    {
      "name": "release",
      "displayName": "Build Release",
      "configurePreset": "release",
      "jobs": 0
    },
    {
      "name": "linux-debug",
      "displayName": "Build Linux/Unix Debug",
      "configurePreset": "linux-debug",
      "jobs": 0
    }
  ],

  "testPresets": [
    {
      "name": "unit",
      "displayName": "Unit Tests",
      "configurePreset": "debug",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 4, "timeout": 60 }
    },
    {
      "name": "linux-unit",
      "displayName": "Unit Tests (Linux/Unix)",
      "configurePreset": "linux-debug",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 4, "timeout": 60 }
    }
  ]
}
